{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Stryker mutation testing configuration for the kanban package",
  "packageManager": "pnpm",
  "testRunner": "command",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts"
  ],
  "commandRunner": {
    "command": "ava --config=ava.config.local.mjs"
  },
  "reporters": ["progress", "clear-text", "html", "json"],
  "htmlReporter": {
    "fileName": "reports/mutation/html/index.html"
  },
  "jsonReporter": {
    "fileName": "reports/mutation/mutation-report.json"
  },
  "tempDirName": "stryker-tmp",
  "concurrency": 2,
  "timeoutMS": 300000,
  "logLevel": "info"
}