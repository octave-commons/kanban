{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "kanban-cli",
  "projectType": "library",
  "sourceRoot": "cli/kanban/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban run build"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban test"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban test:coverage"
      },
      "dependsOn": ["build"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm --filter @promethean-os/kanban run typecheck"
      }
    }
  }
}
